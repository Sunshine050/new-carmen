# Copy to .env.docker and use: docker compose --env-file .env.docker up --build
#
# หลัง stack ขึ้น — migration ครั้งแรก: ./scripts/migrate-docker.sh (ดู backend/migrations/README.md)

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carmen_db
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000
CHATBOT_PORT=8000

ENVIRONMENT=production
CORS_ORIGINS=*

JWT_SECRET=change-me-long-random-string

# ใช้ร่วมกันระหว่าง Go backend กับ Python chatbot (≥32 ตัวอักษร — chatbot บังคับ)
# สร้าง: openssl rand -hex 32
PRIVACY_HMAC_SECRET=changeme-use-openssl-rand-hex-32-in-production

# Public URL the browser uses to call the API (same host as frontend or your API domain)
NEXT_PUBLIC_API_BASE=http://localhost:8080

DB_SCHEMA=carmen,public

# Path ใน container ไปยังโฟลเดอร์ wiki (repo mount ที่ /repo)
WIKI_CONTENT_PATH=/repo/carmen_cloud

GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_BRANCH=main
GITHUB_TOKEN=

OPENROUTER_API_KEY=
OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b

# โมเดลแชท (ฝั่ง Python chatbot — ส่งเป็น env ได้ถ้า compose รองรับ)
# LLM_CHAT_MODEL=stepfun/step-3.5-flash:free
# LLM_INTENT_MODEL=google/gemini-2.5-flash-lite
# LLM_API_BASE=https://openrouter.ai/api/v1

GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_ENABLED=false
