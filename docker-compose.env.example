# Copy to .env.docker and use: docker compose --env-file .env.docker up --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carmen_db
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000

ENVIRONMENT=production
CORS_ORIGINS=*

JWT_SECRET=change-me-long-random-string

# Public URL the browser uses to call the API (same host as frontend or your API domain)
NEXT_PUBLIC_API_BASE=http://localhost:8080

DB_SCHEMA=carmen,public

# Path ใน container ไปยังโฟลเดอร์ wiki (repo mount ที่ /repo)
WIKI_CONTENT_PATH=/repo/carmen_cloud

GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_BRANCH=main
GITHUB_TOKEN=

OPENROUTER_API_KEY=
OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b

GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_ENABLED=false
