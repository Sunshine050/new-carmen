# Server
SERVER_PORT=8080
SERVER_HOST=localhost
ENVIRONMENT=development
CORS_ORIGINS=*

# Database (Neon หรือ PostgreSQL)
# ถ้าใช้ Neon: ใส่ host จาก Neon, DB_SSLMODE=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=carmen_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# Ollama (ถ้าใช้)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# GitHub (สำหรับ indexing จาก repo)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_BRANCH=main

# Git / Wiki content paths
# หลัก: ใช้ carmen_cloud ที่ project root (อยู่ใน repo, pull มาได้ — ไม่ต้องตั้งอะไร)
# WIKI_CONTENT_PATH: override ได้ถ้า path ต่างออกไป (เช่น รันจากที่อื่น)
GIT_REPO_PATH=./wiki-content
GIT_REPO_URL=
# WIKI_CONTENT_PATH=

# Wiki Search (optional — ค่า default ใช้ได้ทั่วไป)
# WIKI_SEARCH_LIMIT=20
# WIKI_VECTOR_DISTANCE_MAX=0.3
# WIKI_SNIPPET_MAX_LEN=200

# Chat context (optional — ค่า default ใช้ได้ทั่วไป)
# CHAT_CONTEXT_LIMIT=10
# CHAT_MAX_CONTEXT_CHARS=8000
# CHAT_MAX_CHUNK_CONTENT=2000

# OpenClaw (ถ้าใช้สำหรับแยกประเภทคำถาม — ถ้าไม่ใช้ Make)
# OPENCLAW_GATEWAY_URL=
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_MODEL=default
# OPENCLAW_ENABLED=true

# Make (ทางเลือกแทน OpenClaw สำหรับแยกประเภทคำถาม)
# ตั้ง USE_MAKE_FOR_ROUTER=true และ MAKE_WEBHOOK_URL=... แล้ว backend จะเรียก Make แทน OpenClaw
# ถ้าใน Make เปิด API Key authentication ให้ใส่ key เดียวกันที่ MAKE_WEBHOOK_API_KEY
# USE_MAKE_FOR_ROUTER=false
# MAKE_WEBHOOK_URL=
# MAKE_WEBHOOK_API_KEY=
