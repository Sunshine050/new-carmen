# =============================================================================
# แยก 3 ฝั่ง — ไม่ได้ copy ไฟล์ .env เดียวกันไปทุกที่
# =============================================================================
#
# 1) BACKEND (Fly / Railway / VPS)  ← ใช้เฉพาะตัวแปรที่ Go อ่าน (เหมือน backend/.env แต่ค่า production)
#    ไม่ใส่ NEXT_PUBLIC_* ที่นี่
#
# 2) FRONTEND (Vercel)  ← มีหลักๆ แค่ NEXT_PUBLIC_API_BASE = URL ของ backend จริง (https://... ไม่ใช่ localhost)
#    ไม่ใส่ DB_*, JWT, OPENROUTER ที่นี่ (ยกเว้นโปรเจกต์มี NEXT_PUBLIC อื่นจริงๆ)
#
# 3) CHATBOT Python (service แยก ถ้ามี)  ← ใช้ LLM_*, DB_*, PRIVACY_HMAC_SECRET ตาม carmen-chatbot/backend/core/config.py
#    ไม่ใช่ copy ไฟล์ carmen-chatbot/.env เก่าแบบเดียวถ้าชื่อตัวแปรไม่ตรงโค้ดปัจจุบัน
#
# ไฟล์ backend/.env + carmen-chatbot/.env + frontend .env.local = DEV บนเครื่องเท่านั้น
# =============================================================================
#
# ตัวอย่าง environment สำหรับ deploy backend บน Fly.io
# วิธีใช้: คัดลอกเป็นไฟล์ชั่วคราว แก้ค่าจริง แล้ว import (อย่า commit ไฟล์ที่มีความลับ)
#
#   fly secrets import -a new-carmen < .env.fly.local
#
# หรือใส่ทีละตัวใน Fly Dashboard → App → Secrets
#
# --- DB (บังคับ) ---
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database
DB_SSLMODE=require
DB_SCHEMA=carmen,public

# --- แอป / ความปลอดภัย (บังคับ production) ---
ENVIRONMENT=production
STRICT_ENV_ONLY=true
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
JWT_SECRET=generate_with_openssl_rand_hex_32
PRIVACY_HMAC_SECRET=must_be_at_least_32_chars_same_as_chatbot_if_used

# CORS: หลังมี Vercel เปลี่ยนเป็น https://your-app.vercel.app (หรือหลายค่าคั่นด้วย comma)
CORS_ORIGINS=https://your-app.vercel.app
ADMIN_API_KEY=generate_with_openssl_rand_hex_32
INTERNAL_API_KEY=generate_with_openssl_rand_hex_32

# --- LLM / OpenRouter (ใช้ embedding + ฟีเจอร์ที่เรียก API) ---
OPENROUTER_API_KEY=sk-or-v1-...
LLM_API_KEY=sk-or-v1-...
OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
LLM_EMBED_MODEL=qwen/qwen3-embedding-8b
LLM_CHAT_MODEL=openai/gpt-4o-mini
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_TIMEOUT_SECONDS=60

# --- Python chatbot (ถ้ามี deploy แยก — ใส่ URL จริง) ---
PYTHON_CHATBOT_URL=https://your-chatbot.fly.dev

# --- GitHub / wiki sync ---
GITHUB_TOKEN=
GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_REPO_BASE_URL=https://github.com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_BRANCH=main
GITHUB_WEBHOOK_BRANCH=main
GITHUB_WEBHOOK_SECRET=replace_with_real_secret
GIT_REPO_URL=https://github.com/Sunshine050/new-carmen.git
# บน Fly ไม่มีโฟลเดอร์ repo — ปล่อยว่างหรือตามที่แอป sync รองรับ
GIT_REPO_PATH=
WIKI_CONTENT_PATH=
GIT_SYNC_BRANCH=main
WIKI_DEFAULT_BU=carmen
WIKI_CARMEN_PATHS=/app/carmen_cloud
WIKI_CARMEN_GIT_PATH=carmen_cloud
WIKI_CHUNK_SIZE=500
WIKI_CHUNK_OVERLAP=100
WIKI_SEARCH_LIMIT=20
WIKI_VECTOR_DISTANCE_MAX=0.3
WIKI_SNIPPET_MAX_LEN=200
CHAT_CONTEXT_LIMIT=10
CHAT_MAX_CONTEXT_CHARS=8000
CHAT_MAX_CHUNK_CONTENT=2000
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_SIMILARITY_THRESHOLD=0.15
INDEXING_TIMEOUT_MINUTES=60
WEBHOOK_INDEXING_TIMEOUT_MINUTES=30
OPENCLAW_URL=
OPENCLAW_TOKEN=
OPENCLAW_MODEL=
OPENCLAW_ENABLED=false
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_API_KEY=
MAKE_USE_FOR_ROUTER=false
VECTOR_DIMENSION=1536

# --- แปล (ไม่ใช้ = ปิด) ---
TRANSLATION_ENABLED=false
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_API_BASE_URL=https://translation.googleapis.com/language/translate/v2
TRANSLATION_TIMEOUT_SECONDS=30

JWT_EXPIRY=24h

# PORT ถูกตั้งโดย Fly — ไม่ต้องใส่ยกเว้นต้องการ override
