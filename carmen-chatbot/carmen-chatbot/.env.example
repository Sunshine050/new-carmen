# --- Carmen Chatbot Environment Variables Example ---

# Mode: production or development
ENVIRONMENT=development

# --- LLM Providers ---
# Options: openrouter, ollama, zai
ACTIVE_LLM_PROVIDER=openrouter

# OpenRouter Settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_CHAT_MODEL=stepfun/step-3.5-flash:free

# Ollama Settings (Local AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:1b
OLLAMA_EMBED_MODEL=qwen3-embedding:8b

# Z.ai Settings
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4
ZAI_CHAT_MODEL=gpt-4o

# --- Database Settings (PostgreSQL + pgvector) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ai
DB_SSLMODE=disable
DB_SCHEMA=carmen,public

# --- Vector Settings ---
VECTOR_DIMENSION=1536

# --- App Settings ---
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=20/minute
WIKI_CONTENT_PATH=../carmen_cloud
FRONTEND_DIR=carmen-chatbot-widget/dist
IMAGES_DIR=images
