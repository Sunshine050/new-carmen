# --- Carmen Chatbot Environment Variables Example ---

ENVIRONMENT=development

# --- LLM Provider (OpenAI-compatible API) ---
# ใส่ API key ของ provider ที่ใช้ (OpenRouter, KNPLabs, Together, Groq, etc.)
LLM_API_KEY=your_api_key_here
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=google/gemini-2.5-flash-lite
LLM_INTENT_MODEL=google/gemini-2.5-flash-lite
LLM_EMBED_MODEL=qwen/qwen3-embedding-8b
LLM_FALLBACK_MODEL=

# --- Database Settings (PostgreSQL + pgvector) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ai
DB_SSLMODE=disable
DB_SCHEMA=carmen,public

# --- Vector Settings ---
VECTOR_DIMENSION=1536

# --- App Settings ---
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=20/minute
DAILY_REQUEST_LIMIT=500
MAX_PROMPT_TOKENS=6000
WIKI_CONTENT_PATH=../carmen_cloud

# --- Optional ---
GO_BACKEND_URL=
PRIVACY_HMAC_SECRET=   # Required: ≥32 chars random string — generate: openssl rand -hex 32
